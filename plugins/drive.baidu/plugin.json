{
  "id": "drive.baidu",
  "name": "百度网盘驱动插件",
  "version": "1.0.0",
  "category": "drive",
  "description": "百度网盘分享链接解析与转存驱动插件，支持 Cookie 认证、分享浏览、文件转存到指定目录",
  "author": "T3FAP Community",
  "homepage": "",
  "license": "MIT",
  "core_version": ">=1.0.0 <2.0.0",
  "contract_version": "1.0",
  "capabilities": [
    "drive.account",
    "drive.fs",
    "drive.share",
    "drive.download"
  ],
  "backend": {
    "entry": "backend.plugin:plugin"
  },
  "permissions": [
    "network",
    "secret.read"
  ],
  "dependencies": [],
  "optional_dependencies": [],
  "config_schema": [
    {
      "key": "bduss",
      "label": "BDUSS Cookie",
      "type": "string",
      "required": true,
      "default": "",
      "description": "百度网盘 BDUSS Cookie 值，登录 pan.baidu.com 后从浏览器开发者工具获取",
      "secret": true,
      "group": "账号认证"
    },
    {
      "key": "stoken",
      "label": "STOKEN Cookie",
      "type": "string",
      "required": true,
      "default": "",
      "description": "百度网盘 STOKEN Cookie 值，与 BDUSS 一起从浏览器获取",
      "secret": true,
      "group": "账号认证"
    },
    {
      "key": "ptoken",
      "label": "PTOKEN Cookie",
      "type": "string",
      "required": false,
      "default": "",
      "description": "百度网盘 PTOKEN Cookie 值（可选，部分操作可能需要）",
      "secret": true,
      "group": "账号认证"
    },
    {
      "key": "default_save_dir",
      "label": "默认转存目录",
      "type": "string",
      "required": false,
      "default": "/",
      "description": "转存文件时默认保存到的网盘目录路径，例如 /T3FAP",
      "secret": false,
      "group": "转存设置"
    },
    {
      "key": "request_interval",
      "label": "请求间隔（秒）",
      "type": "integer",
      "required": false,
      "default": 2,
      "description": "API 请求之间的最小间隔秒数，避免触发百度频率限制",
      "secret": false,
      "group": "转存设置"
    },
    {
      "key": "timeout_seconds",
      "label": "请求超时（秒）",
      "type": "integer",
      "required": false,
      "default": 15,
      "description": "单个 HTTP 请求的超时时间",
      "secret": false,
      "group": "转存设置"
    },
    {
      "key": "retry_count",
      "label": "失败重试次数",
      "type": "integer",
      "required": false,
      "default": 2,
      "description": "API 请求失败时的重试次数",
      "secret": false,
      "group": "转存设置"
    }
  ],
  "ui": {
    "menus": [],
    "settings_sections": [
      {
        "key": "drive.baidu.settings",
        "title": "百度网盘配置"
      }
    ],
    "task_templates": []
  },
  "healthcheck": {
    "enabled": true,
    "interval_seconds": 300
  }
}
